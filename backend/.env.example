DATABASE_URL=sqlite+aiosqlite:///./data/app.db
SECRET_KEY=change-me-to-a-long-random-string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
FRONTEND_ORIGIN=http://localhost:3000
COOKIE_SECURE=false
EIA_API_KEY=change-me-to-your-eia-api-key
LOG_LEVEL=INFO
LOG_DIR=./data/logs
LOG_FILE_MAX_BYTES=100000000
LOG_FILE_BACKUP_COUNT=100
LOG_QUEUE_MAX_SIZE=10000
LOG_MAX_RECENT_SCAN_LINES=5000
RATE_LIMIT_REGISTER=10/minute
RATE_LIMIT_LOGIN=10/minute
RATE_LIMIT_REFRESH=10/minute
RATE_LIMIT_FORECAST_CREATE=10/minute
RATE_LIMIT_OIL_FETCH=10/minute
